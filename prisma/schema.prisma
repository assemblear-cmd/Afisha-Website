generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  // role: "visitor" | "organizer"
  role         String   @default("visitor")
  createdAt    DateTime @default(now())
  events       Event[]
  orders       Order[]
}

model Event {
  id          String       @id @default(cuid())
  title       String
  description String
  category    String
  venue       String
  city        String
  address     String
  startsAt    DateTime
  endsAt      DateTime
  coverImage  String
  isPublished Boolean      @default(true)
  organizer   User         @relation(fields: [organizerId], references: [id])
  organizerId String
  ticketTypes TicketType[]
  orders      Order[]
  createdAt   DateTime     @default(now())
}

model TicketType {
  id         String      @id @default(cuid())
  name       String
  priceCents Int
  quantity   Int
  sold       Int         @default(0)
  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId    String
  orderItems OrderItem[]
}

model Order {
  id         String      @id @default(cuid())
  buyerName  String
  buyerEmail String
  totalCents Int
  // status: "paid"
  status     String      @default("paid")
  event      Event       @relation(fields: [eventId], references: [id])
  eventId    String
  user       User?       @relation(fields: [userId], references: [id])
  userId     String?
  items      OrderItem[]
  createdAt  DateTime    @default(now())
}

model OrderItem {
  id             String     @id @default(cuid())
  order          Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        String
  ticketType     TicketType @relation(fields: [ticketTypeId], references: [id])
  ticketTypeId   String
  quantity       Int
  unitPriceCents Int
}

// --- Scraped theater repertoire (the daily-updated aggregator) --------------
// A Theater is a source site we scan; its Shows are the repertoire entries
// pulled from that site. This is separate from the user-generated Event model
// above (which powers the ticketing MVP).

model Theater {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  website       String
  city          String    @default("Santiago")
  // Scraper adapter key (e.g. "municipal", "gam"); null = no adapter yet.
  adapter       String?
  isActive      Boolean   @default(true)
  // Per-theater scan state — one site failing never blocks the others.
  lastScrapedAt DateTime?
  lastScrapeOk  Boolean?
  lastError     String?
  shows         Show[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Show {
  id          String    @id @default(cuid())
  theater     Theater   @relation(fields: [theaterId], references: [id], onDelete: Cascade)
  theaterId   String
  // Stable identity from the source (url / @id / hash) for upsert dedup.
  externalId  String
  title       String
  description String?
  startsAt    DateTime?
  endsAt      DateTime?
  venue       String?
  category    String?
  // Raw price label from the source; priceCents is the parsed value when known.
  priceText   String?
  priceCents  Int?
  currency    String    @default("CLP")
  sourceUrl   String?
  imageUrl    String?
  // Scan bookkeeping: when first/last seen, and whether still on the calendar.
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([theaterId, externalId])
  @@index([startsAt])
}
