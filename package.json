{
  "name": "afisha-website",
  "version": "0.1.0",
  "private": true,
  "description": "Afisha — discover and sell tickets to events. An Eventbrite-style MVP.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:sync-theaters": "tsx prisma/sync-theaters.ts",
    "db:sync-commerce": "tsx prisma/sync-commerce.ts",
    "db:scrape": "tsx prisma/run-scrape.ts",
    "db:cleanup-events": "tsx prisma/cleanup-events.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "setup": "prisma db push && tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "clsx": "2.1.1",
    "jose": "5.9.6",
    "jsqr": "^1.4.0",
    "next": "14.2.18",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "^22.3.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "1.48.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.9.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.3",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.18",
    "jsdom": "25.0.1",
    "postcss": "8.4.47",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.14",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
