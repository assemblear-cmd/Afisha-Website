# Copy this file to .env and fill in real values.
#
# DATABASE_URL — PostgreSQL connection string. Get a free database from
# Neon (https://neon.tech) or Supabase (https://supabase.com) and paste its
# connection string here. Use the same value locally and on Vercel.
#   postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/afisha?sslmode=require"
#
# AUTH_SECRET — signs the session JWT. Use a long random string in production
# (e.g. `openssl rand -base64 32`).
AUTH_SECRET="change-me-to-a-long-random-string"

# Secret for the daily cron route (/api/cron/scrape-theaters)
CRON_SECRET="set-a-strong-secret-in-production"

# GOOGLE_CLIENT_ID — OAuth *web* client ID (from Google Cloud Console) used to
# verify the ID token from the mobile "Sign in with Google" flow. It must match
# the `serverClientId` the Android app is built with
# (`-PdondegoGoogleClientId=`). Comma-separate to accept more than one client.
# Leave empty to disable Google sign-in (the app hides the button; the endpoint
# returns 501).
GOOGLE_CLIENT_ID=""

# --- Organizer/commerce module -------------------------------------------
# Stripe payments (tickets, homepage tiles, promo services). Get keys from
# https://dashboard.stripe.com/apikeys. The webhook secret comes from
# `stripe listen --forward-to localhost:3000/api/webhooks/stripe` locally or
# the dashboard webhook endpoint in production.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Only needed if a client-side Stripe.js integration is added later.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Base URL used for Stripe success/cancel redirects.
APP_URL="http://127.0.0.1:3000"

# Admin account created by `npm run db:seed` / `npm run db:sync-commerce`.
ADMIN_SEED_EMAIL="admin@dondego.test"
ADMIN_SEED_PASSWORD=""

# Set to 1 to disable in-process API rate limiting (see docs/rate-limiting.md).
# Meant for e2e/CI runs and local load testing — never enable in production.
# RATE_LIMIT_DISABLED=1
