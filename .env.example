# Copy this file to .env and fill in real values.
#
# DATABASE_URL — PostgreSQL connection string. Get a free database from
# Neon (https://neon.tech) or Supabase (https://supabase.com) and paste its
# connection string here. Use the same value locally and on Vercel.
#   postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/afisha?sslmode=require"
#
# AUTH_SECRET — signs the session JWT. Use a long random string in production
# (e.g. `openssl rand -base64 32`).
AUTH_SECRET="change-me-to-a-long-random-string"

# Secret for the daily cron route (/api/cron/scrape-theaters)
CRON_SECRET="set-a-strong-secret-in-production"
